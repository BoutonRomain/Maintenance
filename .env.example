# Configuration du serveur
PORT=3000
NODE_ENV=development

# Configuration de la base de données SQLite (par défaut)
DB_STORAGE=./db.sqlite

# Configuration pour PostgreSQL (décommenter si utilisé)
# DB_NAME=manageschedule
# DB_USER=postgres
# DB_PASSWORD=password
# DB_HOST=localhost
# DB_PORT=5432

# Configuration pour MySQL (décommenter si utilisé)
# DB_NAME=manageschedule
# DB_USER=root
# DB_PASSWORD=password
# DB_HOST=localhost
# DB_PORT=3306

# Secrets
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRE=7d

# CORS
CORS_ORIGIN=http://localhost:8080